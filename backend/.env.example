# These are the values that differ from shop to shop.
# Copy this file to .env and fill in one set per shop.

# Shop identity
SHOP_NAME="The Barber Shop"
SHOP_TIMEZONE="Europe/Lisbon"

# Starting brand colours (any hex). The owner recolours the site live from the
# UI; these are just the defaults and the fallback before anything is saved.
SHOP_BRAND="#9e7b53"
SHOP_BACKGROUND="#f6f1e9"
# Headline shown on the sign-in page. The owner can change it live from the UI;
# this is just the default and the fallback before anything is saved.
SHOP_HEADLINE="A sua cadeira está à espera"
# Optional: seed the logo from a file on first start (owner can replace it later
# from the UI). Leave empty to use the bundled default.
SHOP_LOGO_PATH=""

# Each shop gets its own isolated database (SQLite locally, Postgres in prod)
DATABASE_URL="sqlite:///./barber.db"

# Each shop gets its own JWT signing secret (use a long random string)
JWT_SECRET="change-me-to-a-long-random-string"

# The shop owner — created as an admin on first startup
OWNER_EMAIL="owner@theshop.com"
OWNER_NAME="Owner Name"
OWNER_PASSWORD="change-me"

# Browser origins allowed to call the API (comma-separated; "*" for any)
CORS_ORIGINS="http://localhost:5173"

# Public URL the app is reached at — used to build links in emails
PUBLIC_BASE_URL="http://localhost:8000"

# Frontend URL used for links in emails that open a page (e.g. password reset).
# Leave empty to fall back to PUBLIC_BASE_URL.
FRONTEND_URL="http://localhost:3000"

# Transactional email (verification & password-reset links).
#
# Dev: docker-compose runs Mailpit, which needs no login and no TLS.
#   SMTP_HOST="smtp"  SMTP_PORT="1025"  (leave the auth/TLS lines below empty)
# Leave SMTP_HOST empty to disable sending entirely (e.g. in tests).
SMTP_HOST="smtp"
SMTP_PORT="1025"
SMTP_FROM="no-reply@theshop.com"

# Prod: relay through a dedicated mailbox (e.g. no-reply@theshop.com) at your
# mail provider. Turn on STARTTLS and log in with the mailbox's SMTP username
# and an app-password. Example (Google Workspace / Fastmail / Zoho, etc.):
#   SMTP_HOST="smtp.your-provider.com"
#   SMTP_PORT="587"
#   SMTP_FROM="no-reply@theshop.com"
#   SMTP_STARTTLS="true"
#   SMTP_USERNAME="no-reply@theshop.com"
#   SMTP_PASSWORD="the-app-password"
SMTP_STARTTLS="false"
SMTP_USERNAME=""
SMTP_PASSWORD=""
